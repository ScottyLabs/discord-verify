# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Keycloak Configuration
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=your_realm

# OIDC client for web app (Kennel writes OIDC_* on deploy; KEYCLOAK_OIDC_* still accepted)
OIDC_CLIENT_ID=discord-verify
OIDC_CLIENT_SECRET=your_client_secret

# Admin API Client
KEYCLOAK_ADMIN_CLIENT_ID=discord-verify-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=your_admin_client_secret

# Application URL (for OIDC redirects)
APP_URL=https://verify.example.com

# Redis Configuration
REDIS_URL=redis://discord-verify-redis:6379 # or redis://localhost:6379 for local dev

# Logging Configuration (optional)
RUST_LOG=info,axum_oidc=debug,tower_sessions=debug,tower_http=debug,discord_verify=debug
